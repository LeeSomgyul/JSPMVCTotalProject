<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<!-- DB에 전송할 실제 SQL 쿼리문을 모아두는 곳 (자바 코드와 분리 목적) -->
<mapper namespace="com.sist.mapper.seoul-mapper">
	
	<!-- 특정 테이블(${table})에서 원하는 시작 지점(${start})부터 12개 데이터만 골라서, SeoulVO 객체 리스트로 반환 -->
	<select id="seoulListData" resultType="SeoulVO" parameterType="hashmap">
		SELECT no,poster,title
		FROM ${table}
		ORDER BY no ASC
		OFFSET #{start} ROWS FETCH NEXT 12 ROWS ONLY
	</select>
	
	<!-- 데이터의 총 개수를 구해서 전체 페이지 수가 몇 페이지까지 나올지 계산 -->
	<select id="seoulTotalPage" resultType="int" parameterType="hashmap">
		SELECT CEIL(COUNT(*)/12.0) FROM ${table}
	</select>
	<update id="hitIncrement" parameterType="hashmap">
		UPDATE ${table} SET
		hit = hit+1
		WHERE no=#{no}
	</update>
	<select id="seoulDetailData" resultType="SeoulVO" parameterType="hashmap">
		SELECT *
		FROM ${table}
		WHERE no=#{no}
	</select>
</mapper>